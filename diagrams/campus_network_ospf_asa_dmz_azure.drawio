        <mxCell id="legendVLAN" parent="1" style="swimlane;startSize=40;fillColor=#f5f5f5;strokeColor=#616161;fontStyle=1;fontSize=13;fontColor=#212121;rounded=1;" value="VLANs por Edificio y Planta" vertex="1">
          <mxGeometry height="560" width="700" x="2620" y="290" as="geometry" />
        </mxCell>
        <mxCell id="legendVLANtext" parent="legendVLAN" style="text;html=0;whiteSpace=wrap;align=left;verticalAlign=top;fontSize=13;fontFamily=Courier New;" value="EDIFICIO A&#xa;  VLAN 10  →  IT + Diseñadores + Traductores  (Planta 1)&#xa;  VLAN 20  →  Redactores / Contenido  (Planta 2)&#xa;  VLAN 30  →  Ventas  (Planta 3)&#xa;  VLAN 110 →  Servidores A  (CPD A)&#xa;  VLAN 99  →  Gestión (Mgmt)&#xa;&#xa;EDIFICIO B&#xa;  VLAN 40  →  Invitados Cafetería  (Planta 1)&#xa;  VLAN 50  →  RRHH + Médico  (Planta 2)&#xa;  VLAN 120 →  Servidores B  (CPD B)&#xa;  VLAN 99  →  Gestión (Mgmt)&#xa;&#xa;EDIFICIO C&#xa;  VLAN 60  →  Finanzas  (Planta 1)&#xa;  VLAN 70  →  Operaciones  (Planta 2)&#xa;  VLAN 80  →  CTO  (Planta 3)&#xa;  VLAN 130 →  Servidores Críticos C  (CPD C)&#xa;  VLAN 99  →  Gestión (Mgmt)&#xa;&#xa;DMZ:    VLAN 200 → 172.16.0.0/24&#xa;Azure:  172.16.100.0/24  (Simulación)" vertex="1">
          <mxGeometry height="500" width="660" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="legendIP" parent="1" style="swimlane;startSize=40;fillColor=#f5f5f5;strokeColor=#616161;fontStyle=1;fontSize=13;fontColor=#212121;rounded=1;" value="Plan de Direccionamiento IP" vertex="1">
          <mxGeometry height="560" width="700" x="2620" y="880" as="geometry" />
        </mxCell>
        <mxCell id="legendIPtext" parent="legendIP" style="text;html=0;whiteSpace=wrap;align=left;verticalAlign=top;fontSize=13;fontFamily=Courier New;" value="Usuario:&#xa;  VLAN 10  →  192.168.10.0/24   (GW .1)&#xa;  VLAN 20  →  192.168.20.0/24&#xa;  VLAN 30  →  192.168.30.0/24&#xa;  VLAN 40  →  192.168.40.0/24&#xa;  VLAN 50  →  192.168.50.0/24&#xa;  VLAN 60  →  192.168.60.0/24&#xa;  VLAN 70  →  192.168.70.0/24&#xa;  VLAN 80  →  192.168.80.0/24&#xa;  VLAN 99  →  192.168.99.0/24   (Gestión)&#xa;&#xa;Servidores:&#xa;  VLAN 110 →  192.168.110.0/24&#xa;  VLAN 120 →  192.168.120.0/24&#xa;  VLAN 130 →  192.168.130.0/24&#xa;&#xa;Backbone OSPF:&#xa;  A–B  →  10.0.0.0/30&#xa;  A–C  →  10.0.0.4/30&#xa;  B–C  →  10.0.0.8/30&#xa;  ASA–RouterC  →  10.255.255.0/30&#xa;&#xa;DMZ:  172.16.0.0/24  (ASA dmz: .1)" vertex="1">
          <mxGeometry height="500" width="660" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="legendSec" parent="1" style="swimlane;startSize=40;fillColor=#ffebee;strokeColor=#c62828;fontStyle=1;fontSize=13;fontColor=#b71c1c;rounded=1;" value="Políticas de Seguridad  (ASA + ACL)" vertex="1">
          <mxGeometry height="520" width="700" x="2620" y="1470" as="geometry" />
        </mxCell>
        <mxCell id="legendSectext" parent="legendSec" style="text;html=0;whiteSpace=wrap;align=left;verticalAlign=top;fontSize=13;fontFamily=Courier New;" value="Segmentación:&#xa;  • Invitados (VLAN 40) → Solo Internet DENY hacia 192.168.0.0/16&#xa;  • Ventas (VLAN 30) → DENY a Finanzas (VLAN 60)&#xa;  • Mgmt (VLAN 99) → Solo acceso desde IT (VLAN 10)&#xa;&#xa;DMZ:&#xa;  • DMZ NO puede iniciar conexiones a INSIDE&#xa;  • Internet → DMZ-WEB: permit tcp 80/443&#xa;  • Internet → DMZ-DNS: permit udp/tcp 53&#xa;&#xa;VPN Azure:&#xa;  • Solo redes autorizadas (VLAN 99 + Servidores)&#xa;  • Tráfico cifrado IKEv2 / IPSec&#xa;  • NAT Exempt para redes internas&#xa;&#xa;Hardening general:&#xa;  • SSH solo desde VLAN 99&#xa;  • SNMP v3 solo desde VLAN 99&#xa;  • STP PortFast + BPDUGuard en puertos acceso&#xa;  • DHCP Snooping activado&#xa;  • 802.1X en puertos de usuario" vertex="1">
          <mxGeometry height="620" width="660" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="1YOUKEFOMEQHzwnW60Wu-1" parent="1" style="text;html=1;whiteSpace=wrap;align=center;fontStyle=1;fontSize=18;fontColor=#1a237e;strokeColor=none;fillColor=none;" value="&lt;h2&gt;&lt;font style=&quot;color: rgb(27, 27, 27);&quot;&gt;&lt;font&gt;Diagrama Lógico de Arquitectura de Red de Campus&lt;br&gt;&lt;/font&gt;&lt;font&gt;Campus Network — Backbone OSPF en Anillo · Perímetro ASA · DMZ · VPN Azure&lt;/font&gt;&lt;/font&gt;&lt;/h2&gt;" vertex="1">
          <mxGeometry height="104" width="2500" x="504" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
